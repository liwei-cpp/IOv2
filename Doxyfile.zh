# Doxyfile.zh
PROJECT_NAME           = "IOv2"
OUTPUT_DIRECTORY       = docs
HTML_OUTPUT            = zh
OUTPUT_LANGUAGE        = Chinese
INPUT                  = include
RECURSIVE              = YES
GENERATE_LATEX         = NO
GENERATE_TREEVIEW      = YES

# 提取静态成员和所有变量
EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES

# 将 @lang{ZH} 映射为 \if ZH
ALIASES               += "lang{1}=\if \1"

# 开启 ZH 部分
ENABLED_SECTIONS       = ZH
